<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>Xác minh email - GymLife</title>
    <style type="text/css">
      /* Email client fallbacks & reset */
      .ExternalClass,
      .ReadMsgBody {
        width: 100%;
        background-color: #0b0e17;
      }
      body,
      table,
      td,
      p,
      a {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }
      table,
      td {
        border-collapse: collapse;
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }
      img {
        border: 0;
        height: auto;
        line-height: 100%;
        outline: none;
        text-decoration: none;
        -ms-interpolation-mode: bicubic;
      }
      body {
        margin: 0;
        padding: 0;
        background-color: #0b0e17;
        font-family:
          "Segoe UI",
          system-ui,
          -apple-system,
          "Inter",
          Helvetica,
          Arial,
          sans-serif;
      }
      .yshortcuts a {
        border-bottom: none !important;
      }
      @media screen and (max-width: 600px) {
        .responsive-table {
          width: 100% !important;
        }
        .stack-cell {
          display: block !important;
          width: 100% !important;
          text-align: center !important;
          margin-bottom: 16px !important;
        }
        .btn-inner td {
          display: block !important;
          width: auto !important;
          text-align: center !important;
        }
        .full-width {
          width: 100% !important;
        }
        .padding-mobile {
          padding-left: 20px !important;
          padding-right: 20px !important;
        }
        .h1-mobile {
          font-size: 26px !important;
          line-height: 34px !important;
        }
        .badge-stack {
          display: inline-block !important;
          width: auto !important;
          margin: 6px 10px !important;
        }
      }
      /* Dark mode accent base */
      a {
        color: #00f5a0;
        text-decoration: none;
      }
      .btn-primary {
        background-color: #ff5e3a;
        border-radius: 60px;
        transition: background 0.2s;
      }
      .btn-primary a {
        background-color: #ff5e3a;
        color: #ffffff !important;
        font-weight: 700;
        text-decoration: none;
        display: inline-block;
        border-radius: 60px;
      }
      .btn-primary a:hover {
        background-color: #e9451f;
      }
    </style>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #0b0e17;
      font-family:
        &quot;Segoe UI&quot;,
        system-ui,
        -apple-system,
        &quot;Inter&quot;,
        Helvetica,
        Arial,
        sans-serif;
    "
  >
    <!--[if (gte mso 9)|(IE)]>
<table width="600" align="center" cellpadding="0" cellspacing="0" border="0">
<tr><td>
<![endif]-->

    <!-- Main container -->
    <table
      align="center"
      width="100%"
      border="0"
      cellpadding="0"
      cellspacing="0"
      style="
        max-width: 600px;
        width: 100%;
        margin: 0 auto;
        background-color: #0b0e17;
      "
    >
      <tr>
        <td align="center" style="padding: 30px 20px 20px 20px">
          <!-- Main card -->
          <table
            width="100%"
            border="0"
            cellpadding="0"
            cellspacing="0"
            style="
              background: #131a29;
              border-radius: 28px;
              box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.5);
              border: 1px solid rgba(0, 245, 160, 0.12);
            "
          >
            <!-- Header / Logo + Slogan -->
            <tr>
              <td align="center" style="padding: 36px 24px 20px 24px">
                <div
                  style="
                    display: inline-block;
                    background: linear-gradient(
                      135deg,
                      #00f5a0 0%,
                      #00d0b5 100%
                    );
                    width: 48px;
                    height: 48px;
                    border-radius: 24px;
                    text-align: center;
                    line-height: 52px;
                    margin-bottom: 12px;
                  "
                >
                  <span
                    style="font-size: 28px; font-weight: 800; color: #0b0e17"
                    >🏋🏼</span
                  >
                </div>
                <h1
                  style="
                    font-size: 34px;
                    font-weight: 800;
                    margin: 16px 0 0 0;
                    color: #ffffff;
                    letter-spacing: -0.5px;
                  "
                >
                  LoongMilkGym
                </h1>
                <p
                  style="
                    font-size: 14px;
                    font-weight: 500;
                    color: #00f5a0;
                    margin: 8px 0 0 0;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                  "
                >
                  KỶ NGUYÊN FITNESS CÁ NHÂN HÓA
                </p>
                <p
                  style="
                    font-size: 15px;
                    font-weight: 400;
                    color: #a3b3d6;
                    margin: 12px 0 0 0;
                  "
                >
                  Tạo lộ trình AI của bạn — Tập thông minh, sống khỏe hơn
                </p>
              </td>
            </tr>

            <!-- Divider with neon effect -->
            <tr>
              <td align="center" style="padding: 0 24px">
                <table
                  width="80"
                  border="0"
                  cellpadding="0"
                  cellspacing="0"
                  style="
                    width: 80px;
                    border-bottom: 2px solid #ff5e3a;
                    margin: 0 auto;
                  "
                >
                  <tr>
                    <td height="2" style="font-size: 0; line-height: 0">
                      &nbsp;
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Main verification content -->
            <tr>
              <td align="center" style="padding: 32px 28px 28px 28px">
                <h2
                  style="
                    font-size: 26px;
                    font-weight: 700;
                    color: #ffffff;
                    margin: 0 0 12px 0;
                    letter-spacing: -0.3px;
                  "
                >
                  Xác minh địa chỉ email ✨
                </h2>
                <p
                  style="
                    font-size: 16px;
                    line-height: 1.5;
                    color: #c9d6f0;
                    margin: 0 0 16px 0;
                    max-width: 440px;
                  "
                >
                  Chào bạn,
                </p>
                <p
                  style="
                    font-size: 16px;
                    line-height: 1.5;
                    color: #c9d6f0;
                    margin: 0 0 20px 0;
                    max-width: 480px;
                  "
                >
                  Cảm ơn bạn đã gia nhập
                  <strong style="color: #00f5a0">GymLife</strong>! Vui lòng xác
                  minh email để kích hoạt tài khoản và bắt đầu hành trình
                  fitness cá nhân hóa với
                  <strong style="color: #ff5e3a">AI Coach 24/7</strong>, thư
                  viện bài tập chuẩn và lộ trình thông minh.
                </p>
                <!-- CTA BUTTON (placeholder link) -->
                <table
                  cellpadding="0"
                  cellspacing="0"
                  border="0"
                  align="center"
                  style="margin: 20px 0 18px 0"
                >
                  <tr>
                    <td
                      align="center"
                      bgcolor="#FF5E3A"
                      style="
                        background-color: #ff5e3a;
                        border-radius: 60px;
                        padding: 0;
                      "
                    >
                      <a
                        href="<%= verificationLink %>"
                        style="
                          display: inline-block;
                          background-color: #ff5e3a;
                          color: #ffffff;
                          font-size: 17px;
                          font-weight: 700;
                          text-decoration: none;
                          padding: 14px 36px;
                          border-radius: 60px;
                          letter-spacing: 0.5px;
                          box-shadow: 0 6px 14px rgba(255, 94, 58, 0.25);
                          transition: all 0.2s;
                        "
                        >XÁC MINH EMAIL NGAY</a
                      >
                    </td>
                  </tr>
                </table>
                <!-- fallback text link -->
                <p
                  style="
                    font-size: 13px;
                    color: #7f8daa;
                    line-height: 1.4;
                    margin: 8px 0 0 0;
                  "
                >
                  Hoặc sao chép liên kết bên dưới:
                </p>
                <p
                  style="
                    font-size: 13px;
                    background-color: #0f1622;
                    padding: 8px 12px;
                    border-radius: 14px;
                    word-break: break-all;
                    color: #a4b5e6;
                    display: inline-block;
                    max-width: 100%;
                    margin: 12px 0 0 0;
                  "
                >
                  <%= verificationLink %>
                </p>
                <p
                  style="
                    font-size: 12px;
                    color: #6e7c9e;
                    margin: 28px 0 0 0;
                    border-top: 1px solid #1e2a3a;
                    padding-top: 20px;
                  "
                >
                  🔒 Liên kết có hiệu lực trong <strong>1 giờ</strong>. Nếu bạn
                  không yêu cầu, hãy bỏ qua email này.
                </p>
              </td>
            </tr>
            <!-- Copyright and social placeholder -->
            <tr>
              <td
                align="center"
                style="
                  padding: 12px 24px 32px 24px;
                  border-top: 1px solid #1e2a3a;
                "
              >
                <p style="font-size: 11px; color: #5c6f96; margin: 0 0 6px 0">
                  &copy; 2025 GymLife — Đồng hành cùng sức mạnh cá nhân
                </p>
                <p style="font-size: 11px; color: #5c6f96; margin: 0">
                  Nhận thông báo này vì bạn đã đăng ký tại GymLife. <br />Nếu có
                  thắc mắc, liên hệ
                  <a
                    href="mailto:support@gymlife.com"
                    style="color: #00f5a0; text-decoration: none"
                    >support@gymlife.com</a
                  >
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
