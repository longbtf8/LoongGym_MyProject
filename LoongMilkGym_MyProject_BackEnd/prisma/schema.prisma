// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  NHÓM BẢNG 1: TÀI KHOẢN & NGƯỜI DÙNG (Account & User Management)         ║
// ║  Quản lý đăng ký, đăng nhập, hồ sơ cá nhân, cài đặt, phiên đăng nhập     ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

model User {
  id              String               @id @default(uuid())
  email           String               @unique
  passwordHash    String               @map("password_hash")
  role            String               @default("USER")
  status          String               @default("ACTIVE")
  emailVerifiedAt DateTime?            @map("email_verified_at")
  lastLoginAt     DateTime?            @map("last_login_at")
  profile         UserProfile?
  settings        UserSetting?
  resetTokens     PasswordResetToken[]
  revokedTokens   RevokedTokens[]
  refreshTokens   RefreshTokens[]

  trainingPlans   UserTrainingPlan[]
  workoutSessions WorkoutSession[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model UserProfile {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")

  fullName           String?   @map("full_name")
  avatarUrl          String?   @map("avatar_url")
  phone              String?
  address            String?
  gender             String?
  birthDate          DateTime? @map("birth_date")
  heightCm           Float?    @map("height_cm")
  weightKg           Float?    @map("weight_kg")
  heightUnit         String?   @default("cm") @map("height_unit")
  weightUnit         String?   @default("kg") @map("weight_unit")
  membershipTier     String?   @default("Standard") @map("membership_tier")
  fitnessLevel       String?   @map("fitness_level")
  goal               String?
  bio                String?
  calorieGoal        Int?      @map("calorie_goal")
  totalWorkoutDays   Int       @default(0) @map("total_workout_days")
  totalCaloriesBurned Float     @default(0) @map("total_calories_burned")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_profile")
}

model UserSetting {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")

  language   String @default("vi")
  unitSystem String @default("metric") @map("unit_system") //imperial đơn vị đo khác 
  theme      String @default("dark")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_settings")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

model RevokedTokens {
  id     String  @id @default(uuid())
  userId String? @map("user_id")

  tokenHash String   @map("token_hash") @db.VarChar(512)
  expiresAt DateTime @map("expires_at")
  reason    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("revoked_tokens")
}

model RefreshTokens {
  id     String  @id @default(uuid())
  userId String? @map("user_id")
  token  String  @map("token_hash") @db.VarChar(512)

  sessionId    String?  @map("session_id")
  deviceName   String?
  ipAddress    String?
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Queues {
  id        String   @id @default(uuid())
  type      String
  payload   String?  @db.VarChar(512)
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("queues")
}

// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  NHÓM BẢNG 2: THƯ VIỆN BÀI TẬP (Exercise Library)                            ║
// ║  Quản lý bài tập, nhóm cơ, thiết bị, hướng dẫn, lỗi thường gặp, thẻ tag      ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

/// Bảng "Nhóm cơ" – Lưu các nhóm cơ trên cơ thể (ngực, lưng, chân, vai, tay trước, tay sau)
/// Hỗ trợ cấu trúc cha-con (ví dụ: "Tay" → "Tay trước", "Tay sau")
model MuscleGroup {
  id       String  @id @default(uuid()) /// Mã định danh duy nhất
  name     String  @db.VarChar(100) /// Tên nhóm cơ (ví dụ: Ngực, Lưng, Chân)
  slug     String  @unique @db.VarChar(100) /// Đường dẫn thân thiện (ví dụ: nguc, lung, chan)
  parentId String? @map("parent_id") /// Mã nhóm cơ cha (null nếu là nhóm gốc)
  imageUrl String? @map("image_url") @db.Text /// Đường dẫn ảnh bản đồ cơ bắp

  parent   MuscleGroup?  @relation("MuscleGroupHierarchy", fields: [parentId], references: [id])
  children MuscleGroup[] @relation("MuscleGroupHierarchy") /// Danh sách nhóm cơ con

  exerciseMuscles ExerciseMuscle[] /// Quan hệ với bảng cơ tác động của bài tập

  createdAt DateTime @default(now()) @map("created_at") /// Ngày tạo bản ghi

  @@map("muscle_groups")
}

/// Bảng "Thiết bị tập" – Lưu danh sách thiết bị tập luyện (tạ đòn, tạ đơn, máy tập, tự trọng)
model Equipment {
  id   String @id @default(uuid()) /// Mã định danh duy nhất
  name String @db.VarChar(100) /// Tên thiết bị (ví dụ: Barbell, Dumbbell, Machine)
  slug String @unique @db.VarChar(100) /// Đường dẫn thân thiện (ví dụ: barbell, dumbbell)

  exercises Exercise[] /// Danh sách bài tập sử dụng thiết bị này

  createdAt DateTime @default(now()) @map("created_at") /// Ngày tạo bản ghi

  @@map("equipment")
}

/// Bảng "Bài tập" – Lưu thông tin chi tiết từng bài tập (Bench Press, Squat, Deadlift,...)
model Exercise {
  id                 String  @id @default(uuid()) /// Mã định danh duy nhất
  name               String  @db.VarChar(150) /// Tên bài tập (ví dụ: Bench Press, Squat)
  slug               String  @unique @db.VarChar(150) /// Đường dẫn thân thiện (ví dụ: bench-press)
  description        String? @db.Text /// Mô tả ngắn gọn về bài tập
  difficulty         String  @db.VarChar(30) /// Độ khó: beginner, intermediate, advanced
  exerciseType       String? @map("exercise_type") @db.VarChar(50) /// Loại bài tập: strength, cardio, mobility, hiit
  primaryEquipmentId String? @map("primary_equipment_id") /// Mã thiết bị chính sử dụng cho bài tập
  estimatedCalories  Float?  @map("estimated_calories") /// Calo ước tính tiêu hao (kcal / 3 set)
  durationSeconds    Int?    @map("duration_seconds") /// Thời gian ước tính thực hiện (giây)
  thumbnailUrl       String? @map("thumbnail_url") @db.Text /// Đường dẫn ảnh đại diện của bài tập
  videoUrl           String? @map("video_url") @db.Text /// Đường dẫn video hướng dẫn bài tập
  isPublished        Boolean @default(false) @map("is_published") /// Trạng thái xuất bản (true = hiển thị cho người dùng)
  viewCount          Int     @default(0) @map("view_count") /// Số lượt xem bài tập

  primaryEquipment Equipment? @relation(fields: [primaryEquipmentId], references: [id])

  muscles        ExerciseMuscle[] /// Danh sách nhóm cơ tác động
  steps          ExerciseStep[] /// Các bước hướng dẫn thực hiện
  commonMistakes ExerciseCommonMistake[] /// Các lỗi kỹ thuật thường gặp
  tags           ExerciseTag[] /// Các thẻ phân loại bài tập

  workoutTemplateExercises WorkoutTemplateExercise[]
  workoutSessionExercises  WorkoutSessionExercise[]

  createdAt DateTime @default(now()) @map("created_at") /// Ngày tạo bản ghi
  updatedAt DateTime @updatedAt @map("updated_at") /// Ngày cập nhật gần nhất

  @@map("exercises")
}

/// Bảng "Cơ tác động của bài tập" – Bảng trung gian liên kết bài tập với nhóm cơ
/// Mỗi bài tập có thể tác động tới nhiều nhóm cơ với vai trò khác nhau (chính/phụ)
model ExerciseMuscle {
  exerciseId    String @map("exercise_id") /// Mã bài tập
  muscleGroupId String @map("muscle_group_id") /// Mã nhóm cơ
  role          String @db.VarChar(20) /// Vai trò tác động: primary (chính), secondary (phụ)

  exercise    Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  muscleGroup MuscleGroup @relation(fields: [muscleGroupId], references: [id])

  @@id([exerciseId, muscleGroupId, role]) /// Khóa chính tổ hợp (bài tập + nhóm cơ + vai trò)
  @@map("exercise_muscles")
}

/// Bảng "Các bước thực hiện bài tập" – Lưu hướng dẫn từng bước chi tiết
model ExerciseStep {
  id          String @id @default(uuid()) /// Mã định danh duy nhất
  exerciseId  String @map("exercise_id") /// Mã bài tập liên kết
  stepOrder   Int    @map("step_order") /// Thứ tự bước (1, 2, 3, 4,...)
  title       String @db.VarChar(150) /// Tiêu đề bước (ví dụ: "Chuẩn bị tư thế")
  instruction String @db.Text /// Nội dung hướng dẫn chi tiết của bước

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") /// Ngày tạo bản ghi

  @@map("exercise_steps")
}

/// Bảng "Lỗi thường gặp" – Lưu các lỗi kỹ thuật phổ biến khi thực hiện bài tập
model ExerciseCommonMistake {
  id          String  @id @default(uuid()) /// Mã định danh duy nhất
  exerciseId  String  @map("exercise_id") /// Mã bài tập liên kết
  title       String  @db.VarChar(150) /// Tiêu đề lỗi (ví dụ: "Lưng bị cong")
  description String? @db.Text /// Mô tả chi tiết lỗi và cách khắc phục
  severity    String  @default("medium") @db.VarChar(30) /// Mức độ nghiêm trọng: low, medium, high

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") /// Ngày tạo bản ghi

  @@map("exercise_common_mistakes")
}

/// Bảng "Thẻ bài tập" – Lưu các tag phân loại bài tập (strength, chest, powerlifting,...)
model ExerciseTag {
  id         String @id @default(uuid()) /// Mã định danh duy nhất
  exerciseId String @map("exercise_id") /// Mã bài tập liên kết
  tag        String @db.VarChar(80) /// Nội dung thẻ (ví dụ: strength, chest, beginner)

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@map("exercise_tags")
}






// NHÓM 3 BẢNG LỘ TRÌNH TẬP LUYỆN
model WorkoutProgram {
  id            String              @id @default(uuid())
  title         String              @db.VarChar(200)
  slug          String              @unique @db.VarChar(200)
  description   String?             @db.Text
  goal          String?             @db.VarChar(50)
  difficulty    String?             @db.VarChar(30)
  coverImageUrl String?             @map("cover_image_url") @db.Text
  createdBy     String?             @map("created_by")
  isPublished   Boolean             @default(false) @map("is_published")
  price         Decimal             @default(0) @db.Decimal(12, 2)
  metadata      Json                @default("{}")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  days          WorkoutProgramDay[]
  userPlans     UserTrainingPlan[]

  @@map("workout_programs")
}

model WorkoutProgramDay {
  id          String            @id @default(uuid())
  programId   String            @map("program_id")
  program     WorkoutProgram    @relation(fields: [programId], references: [id], onDelete: Cascade)
  cycleDay    Int               @map("cycle_day")
  title       String            @db.VarChar(150)
  description String?           @db.Text
  focusArea    String?           @map("focus_area") @db.VarChar(100)
  muscleMapUrl String?           @map("muscle_map_url") @db.Text
  createdAt    DateTime          @default(now()) @map("created_at")
  templates   WorkoutTemplate[]

  @@unique([programId, cycleDay])
  @@map("workout_program_days")
}

model WorkoutTemplate {
  id                       String                    @id @default(uuid())
  programDayId             String?                   @map("program_day_id")
  programDay               WorkoutProgramDay?        @relation(fields: [programDayId], references: [id], onDelete: Cascade)
  title                    String                    @db.VarChar(150)
  description              String?                   @db.Text
  estimatedDurationMinutes Int?                      @map("estimated_duration_minutes")
  createdAt                DateTime                  @default(now()) @map("created_at")
  exercises                WorkoutTemplateExercise[]

  @@map("workout_templates")
}

model WorkoutTemplateExercise {
  id                String          @id @default(uuid())
  workoutTemplateId String          @map("workout_template_id")
  template          WorkoutTemplate @relation(fields: [workoutTemplateId], references: [id], onDelete: Cascade)
  exerciseId        String          @map("exercise_id")
  exercise          Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseOrder     Int             @map("exercise_order")
  sets              Int?
  repsMin           Int?            @map("reps_min")
  repsMax           Int?            @map("reps_max")
  weightKg          Decimal?        @map("weight_kg") @db.Decimal(6, 2)
  restSeconds       Int?            @map("rest_seconds")
  tempo             String?         @db.VarChar(30)
  note              String?         @db.Text

  @@map("workout_template_exercises")
}

model UserTrainingPlan {
  id          String                @id @default(uuid())
  userId      String                @map("user_id")
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId   String?               @map("program_id")
  program     WorkoutProgram?       @relation(fields: [programId], references: [id], onDelete: SetNull)
  title       String                @db.VarChar(200)
  startDate   DateTime              @map("start_date") @db.Date
  status      String                @default("active") @db.VarChar(30)
  aiGenerated Boolean               @default(false) @map("ai_generated")
  aiPrompt    String?               @map("ai_prompt") @db.Text
  metadata    Json                  @default("{}")
  createdAt   DateTime              @default(now()) @map("created_at")
  days        UserTrainingPlanDay[]

  @@map("user_training_plans")
}

model UserTrainingPlanDay {
  id                 String           @id @default(uuid())
  userTrainingPlanId String           @map("user_training_plan_id")
  plan               UserTrainingPlan @relation(fields: [userTrainingPlanId], references: [id], onDelete: Cascade)
  scheduledDate      DateTime         @map("scheduled_date") @db.Date
  title              String           @db.VarChar(150)
  status             String           @default("pending") @db.VarChar(30)
  skipReason         String?          @map("skip_reason") @db.VarChar(100)
  notes              String?          @db.Text
  metadata           Json             @default("{}")
  createdAt          DateTime         @default(now()) @map("created_at")

  workoutSessions    WorkoutSession[]

  @@map("user_training_plan_days")
}


//Nhóm 4 Phiên luyện tập

model WorkoutSession {
  id              String                 @id @default(uuid())
  userId          String                 @map("user_id")
  planDayId       String?                @map("plan_day_id")
  title           String?                @db.VarChar(150)
  startedAt       DateTime?              @map("started_at")
  endedAt         DateTime?              @map("ended_at")
  durationSeconds Int?                   @map("duration_seconds")
  status          String                 @default("in_progress") @db.VarChar(30) // in_progress, completed, cancelled
  perceivedEffort Int?                   @map("perceived_effort") // perceived_effort BETWEEN 1 AND 10
  notes           String?                @db.Text
  createdAt       DateTime               @default(now()) @map("created_at")

  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  planDay         UserTrainingPlanDay?   @relation(fields: [planDayId], references: [id], onDelete: SetNull)
  exercises       WorkoutSessionExercise[]

  @@map("workout_sessions")
}

model WorkoutSessionExercise {
  id               String           @id @default(uuid())
  workoutSessionId String           @map("workout_session_id")
  exerciseId       String           @map("exercise_id")
  exerciseOrder    Int              @map("exercise_order")
  status           String           @default("pending") @db.VarChar(30)
  notes            String?          @db.Text

  workoutSession   WorkoutSession   @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exercise         Exercise         @relation(fields: [exerciseId], references: [id])
  sets             WorkoutSet[]

  @@map("workout_session_exercises")
}

model WorkoutSet {
  id                 String                 @id @default(uuid())
  sessionExerciseId  String                 @map("session_exercise_id")
  setNumber          Int                    @map("set_number")
  setType            String                 @default("working") @db.VarChar(30) @map("set_type") // warmup, working, dropset, failure
  reps               Int?
  weightKg           Decimal?               @map("weight_kg") @db.Decimal(7, 2)
  durationSeconds    Int?                   @map("duration_seconds")
  distanceMeters     Decimal?               @map("distance_meters") @db.Decimal(10, 2)
  rpe                Decimal?               @db.Decimal(3, 1)
  isCompleted        Boolean                @default(false) @map("is_completed")
  completedAt        DateTime?              @map("completed_at")

  sessionExercise    WorkoutSessionExercise @relation(fields: [sessionExerciseId], references: [id], onDelete: Cascade)

  @@map("workout_sets")
}
