// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              String               @id @default(uuid())
  email           String               @unique
  passwordHash    String               @map("password_hash")
  role            String               @default("USER")
  status          String               @default("ACTIVE")
  emailVerifiedAt DateTime?            @map("email_verified_at")
  lastLoginAt     DateTime?            @map("last_login_at")
  profile         UserProfile?
  settings        UserSetting?
  resetTokens     PasswordResetToken[]
  revokedTokens   RevokedTokens[]
  refreshTokens   RefreshTokens[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model UserProfile {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")

  fullName     String?   @map("full_name")
  avatarUrl    String?   @map("avatar_url")
  phone        String?
  address      String?
  gender       String?
  birthDate    DateTime? @map("birth_date")
  heightCm     Float?    @map("height_cm")
  weightKg     Float?    @map("weight_kg")
  heightUnit   String?   @default("cm") @map("height_unit")
  weightUnit   String?   @default("kg") @map("weight_unit")
  membershipTier String?   @default("Standard") @map("membership_tier")
  fitnessLevel String?   @map("fitness_level")
  goal         String?
  bio          String?
  calorieGoal  Int?      @map("calorie_goal")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_profile")
}

model UserSetting {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")

  language   String @default("vi")
  unitSystem String @default("metric") @map("unit_system") //imperial đơn vị đo khác 
  theme      String @default("dark")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_settings")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

model RevokedTokens {
  id     String  @id @default(uuid())
  userId String? @map("user_id")

  tokenHash String   @map("token_hash") @db.VarChar(512)
  expiresAt DateTime @map("expires_at")
  reason    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("revoked_tokens")
}

model RefreshTokens {
  id     String  @id @default(uuid())
  userId String? @map("user_id")
  token  String  @map("token_hash") @db.VarChar(512)

  userAgent    String?
  deviceName   String?
  ipAddress    String?
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Queues {
  id        String   @id @default(uuid())
  type      String
  payload   String?  @db.VarChar(512)
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("queues")
}
